generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Player Universe (Global Data) ───────────────────────────────────────────

model Player {
  id       String @id @default(uuid())
  /// Smart Fantasy Baseball Player ID (PLAYERID column). Primary external key.
  sfbbId        String  @unique @map("sfbb_id")
  playerName    String  @map("player_name")
  /// Player name with diacritics/accents from SFBB FGSPECIALCHAR column. Preferred display name.
  fgSpecialChar String? @map("fg_special_char")
  /// Parsed eligible positions (e.g. ["C","1B"]). Raw CSV may use /, comma, space, or tab as delimiter.
  positions  String[] @default([])
  /// Current MLB team abbreviation, e.g. "LAD", "NYY", "FA"
  team       String?
  /// League level from SFBB LG column: "MLB", "AAA", "AA", etc.
  mlbLevel   String?   @map("mlb_level")
  /// Whether player is fantasy-relevant per SFBB (ACTIVE = "Y")
  active     Boolean   @default(true)
  birthday   DateTime? @db.Date

  firstName  String? @map("first_name")
  lastName   String? @map("last_name")
  /// "L", "R", or "S"
  bats       String?
  /// "L" or "R"
  throws     String?

  // ── Cross-reference IDs ─────────────────────────────────────────────────────
  mlbamId     Int?    @map("mlbam_id")     // MLBID
  fangraphsId String? @map("fangraphs_id") // IDFANGRAPHS (numeric or "sa…" minor-league prefix)
  cbsId       Int?    @map("cbs_id")       // CBSID
  espnId      Int?    @map("espn_id")      // ESPNID
  yahooId     Int?    @map("yahoo_id")     // YAHOOID
  fantraxId   String? @map("fantrax_id")   // FANTRAXID
  retroId     String? @map("retro_id")     // RETROID
  nfbcId      Int?    @map("nfbc_id")      // NFBCID
  bRefId      String? @map("bref_id")      // BREFID
  ottoneuId   Int?    @map("ottoneu_id")   // OTTONEUID

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  stats         PlayerStat[]
  rosterHistory RosterHistory[]
  universe      PlayerUniverse[]
  override      PlayerOverride?

  @@index([positions], type: Gin)
  @@index([fangraphsId])
  @@index([mlbamId])
  @@index([ottoneuId])
  @@map("players")
}

model PlayerUniverse {
  id         String   @id @default(uuid())
  /// "ottoneu" — format key for future multi-format support
  format     String
  ottoneuId  Int      @map("ottoneu_id")
  playerName String   @map("player_name")
  /// Format-specific eligible positions (e.g. ["SP","RP"], ["Util"])
  positions  String[] @default([])
  /// Combined FG key: major-league Int as string, or "sa…" minor-league string
  fangraphsId String?   @map("fangraphs_id")
  mlbamId    Int?      @map("mlbam_id")
  birthday   DateTime? @db.Date
  /// FK to canonical Player; null if player not found in SFBB map
  playerId   String?  @map("player_id")
  player     Player?  @relation(fields: [playerId], references: [id])
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@unique([format, ottoneuId])
  @@index([playerId])
  @@index([fangraphsId])
  @@index([mlbamId])
  @@map("player_universe")
}

model PlayerOverride {
  id          String    @id @default(uuid())
  /// FK to canonical Player; null for manual players not yet in SFBB
  playerId    String?   @unique @map("player_id")
  player      Player?   @relation(fields: [playerId], references: [id])
  /// true = manually added (not from SFBB). Stays true even after auto-linking.
  isManual    Boolean   @default(false) @map("is_manual")
  /// Used for dedup matching during sync/upload
  fangraphsId String?   @map("fangraphs_id")
  mlbamId     Int?      @map("mlbam_id")
  ottoneuId   Int?      @map("ottoneu_id")
  /// Display overrides — null = use the canonical Player field
  displayName String?   @map("display_name")
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  nickname    String?
  birthday    DateTime? @db.Date
  team        String?
  mlbLevel    String?   @map("mlb_level")
  active      Boolean?
  bats        String?
  throws      String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([fangraphsId])
  @@index([mlbamId])
  @@index([ottoneuId])
  @@map("player_overrides")
}

enum StatPlayerType {
  BATTER
  PITCHER
}

enum StatSplit {
  None    @map("none")
  VsLeft  @map("vs_left")
  VsRight @map("vs_right")
}

enum StatProjection {
  None    @map("none")
  ZiPS    @map("zips")
  Steamer @map("steamer")
  ATC     @map("atc")
  TheBat  @map("the_bat")
  TheBatX @map("the_bat_x")
  OOPSY   @map("oopsy")
}

model StatDefinition {
  id           String         @id @default(uuid())
  abbreviation String
  playerType   StatPlayerType @map("player_type")
  name         String?
  description  String?
  /// Format hint e.g. "#.###", "integer", "#.#%"
  format       String?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")

  @@unique([abbreviation, playerType])
  @@map("stat_definitions")
}

model PlayerStat {
  id          String         @id @default(uuid())
  playerId    String         @map("player_id")
  player      Player         @relation(fields: [playerId], references: [id])
  season      Int
  playerType  StatPlayerType  @default(BATTER) @map("player_type")
  projection  StatProjection  @default(None)
  neutralized Boolean         @default(false)
  split       StatSplit       @default(None)
  mlbTeam     String?         @map("mlb_team") @db.VarChar(10)
  /// JSONB: { "HR": 40, "AVG": 0.300, ... }
  stats       Json
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  @@unique([playerId, season, playerType, projection, neutralized, split])
  @@index([season])
  @@index([projection])
  @@map("player_stats")
}

model StatUpload {
  id         String         @id @default(cuid())
  season     Int
  playerType StatPlayerType @map("player_type")
  projection StatProjection
  split      StatSplit
  total      Int
  linked     Int
  skipped    Int
  upserted   Int
  createdAt  DateTime       @default(now()) @map("created_at")

  @@map("stat_uploads")
}

model PlayerMapImport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  total     Int
  inserted  Int
  updated   Int
  deleted   Int

  @@map("player_map_imports")
}

// ─── League & Multi-Tenancy (Clerk Linked) ───────────────────────────────────

model League {
  id            String          @id @default(uuid())
  /// Maps 1:1 to a Clerk Organization ID — the tenancy boundary
  clerkOrgId    String          @unique @map("clerk_org_id")
  leagueName    String          @map("league_name")
  /// FK to LeagueTemplate — drives format, platform, draft, roster config
  templateId    String?         @map("template_id")
  template      LeagueTemplate? @relation(fields: [templateId], references: [id])
  /// URL or deep-link to the league on its host platform. Nullable.
  hostLeagueUrl String?         @map("host_league_url")
  /// Array of 4-digit years the league was active
  seasons       Int[]
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  members LeagueMember[]
  teams   Team[]

  @@index([templateId])
  @@map("leagues")
}

enum LeagueMemberRole {
  COMMISSIONER
  CO_COMMISSIONER
  MANAGER
  CO_MANAGER
  ONLOOKER
}

model LeagueMember {
  clerkUserId String           @map("clerk_user_id")
  leagueId    String           @map("league_id")
  league      League           @relation(fields: [leagueId], references: [id])
  role        LeagueMemberRole
  createdAt   DateTime         @default(now()) @map("created_at")
  deletedAt   DateTime?        @map("deleted_at")

  @@id([clerkUserId, leagueId])
  @@index([leagueId])
  @@index([clerkUserId])
  @@map("league_members")
}

// ─── Team & Roster ────────────────────────────────────────────────────────────

model Team {
  id            String    @id @default(uuid())
  leagueId      String    @map("league_id")
  league        League    @relation(fields: [leagueId], references: [id])
  teamName      String    @map("team_name")
  /// JSONB: { "C_1": "player-uuid", "1B": "player-uuid", "OF_1": null, ... }
  currentRoster Json      @default("{}") @map("current_roster")
  /// JSONB: { "loans_in": 0, "loans_out": 0, "budget": 400, "spent": 0 } — all values in whole dollars
  financeData   Json      @default("{}") @map("finance_data")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  managers      TeamManager[]
  rosterHistory RosterHistory[]

  @@index([leagueId])
  @@map("teams")
}

model TeamManager {
  clerkUserId String    @map("clerk_user_id")
  teamId      String    @map("team_id")
  team        Team      @relation(fields: [teamId], references: [id])
  isPrimary   Boolean   @default(true) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  @@id([clerkUserId, teamId])
  @@index([teamId])
  @@index([clerkUserId])
  @@map("team_managers")
}

model RosterHistory {
  id          String    @id @default(uuid())
  teamId      String    @map("team_id")
  team        Team      @relation(fields: [teamId], references: [id])
  playerId    String    @map("player_id")
  player      Player    @relation(fields: [playerId], references: [id])
  /// Whole dollar salary at time of cut
  salaryAtCut Int?      @map("salary_at_cut")
  cutDate     DateTime  @default(now()) @map("cut_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([teamId])
  @@index([playerId])
  @@map("roster_history")
}

// ─── League Templates ─────────────────────────────────────────────────────────

enum TemplatePlatform {
  ESPN    @map("ESPN")
  Ottoneu @map("Ottoneu")
  Custom  @map("Custom")
}

enum TemplatePlayType {
  H2H    @map("H2H")
  Season @map("Season")
}

/// 5x5 = rotisserie 5×5 | 4x4 = rotisserie 4×4 | fangraphs = FanGraphs linear weights |
/// sabr = SABR linear weights | points = platform-native points (e.g. ESPN)
enum TemplateScoring {
  FiveX5    @map("5x5")
  FourX4    @map("4x4")
  Fangraphs @map("fangraphs")
  SABR      @map("sabr")
  Points    @map("points")
}

enum TemplateDraftMode {
  Live @map("live")
  Slow @map("slow")
}

enum TemplateDraftType {
  Snake   @map("snake")
  Auction @map("auction")
}

model LeagueTemplate {
  id         String            @id @default(uuid())
  /// Human-readable name; unique across all templates
  name       String            @unique
  platform   TemplatePlatform
  playType   TemplatePlayType  @map("play_type")
  scoring    TemplateScoring
  draftMode  TemplateDraftMode @map("draft_mode")
  draftType  TemplateDraftType @map("draft_type")
  teams      Int               @default(12)
  rosterSize Int               @map("roster_size")
  /// Auction salary cap per team. Null for snake drafts.
  /// Typical defaults: 400 (Ottoneu), 260 (ESPN/Custom auction).
  cap        Int?
  /// Ordered array of roster slot positions, e.g. ["C","1B","OF","OF","P","BN"]
  rosters    Json
  isActive   Boolean           @default(true) @map("is_active")
  version    Int               @default(1)
  description String?
  rulesText   String?          @map("rules_text")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  leagues League[]

  @@map("league_templates")
}
